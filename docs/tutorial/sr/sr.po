"  auto row = *iter;\n"
"  //Do something with the row - see above for set/get.\n"
"}</code>"
msgstr ""
"<code>auto children = refModel-&gt;children();\n"
"for (auto iter = children.begin(), end = children.end(); iter != end; ++iter)\n"
